{
  "permissions": {
    "allow": [
      "Bash(git checkout:*)",
      "Bash(git push:*)",
      "Bash(gh auth:*)",
      "Bash(curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg)",
      "Bash(sudo tee:*)",
      "Bash(sudo apt:*)"
    ]
  },
